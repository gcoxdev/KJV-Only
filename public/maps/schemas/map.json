{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "geojson_file": {
        "type": "string",
        "pattern": "^a[0-9a-f]{6}\\.geojson$"
      },
      "translations": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1
      },
      "types": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1
      },
      "verses": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[1-3]?[A-Z]{2,3}\\.[0-9]+\\.[0-9]+$"
        },
        "minItems": 1
      },
      "modern_names": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "required": [
      "geojson_file",
      "translations",
      "types",
      "verses",
      "modern_names"
    ]
  }
}
